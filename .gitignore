# -----------------------------------------------------------------------------
# TinyNet .gitignore
# CMake-based C++20 project, generated for Xcode on macOS.
#
# Ignores build output and generated tooling files only.
# Source, CMakeLists.txt, Makefile, Dockerfile, README.md, LICENSE, docs and
# the common/client/server/examples/tests/.github trees are all tracked.
# -----------------------------------------------------------------------------

# --- Build directories -------------------------------------------------------
build/
cmake-build-*/
out/

# --- Generated Xcode projects / workspaces -----------------------------------
*.xcodeproj/
*.xcworkspace/
xcuserdata/
*.xcuserstate
DerivedData/

# --- CMake temporary / generated files ---------------------------------------
CMakeCache.txt
CMakeFiles/
CMakeScripts/
CMakeUserPresets.json
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
CMakeLists.txt.user
Testing/
_deps/

# --- macOS -------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --- IDE / editor local files ------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# --- Compiled objects / binaries ---------------------------------------------
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe

# --- Logs --------------------------------------------------------------------
*.log
logs/
